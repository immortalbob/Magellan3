<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    Explicit nuget.org source. The <clear/> drops any inherited/broken source list; the <add>
    guarantees the real feed is present so NETStandard.Library and Chorizite.DatReaderWriter
    restore on a normal dev machine.
  -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
